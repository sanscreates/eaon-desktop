{
  "name": "eaon-cli",
  "version": "0.1.0",
  "description": "Eaon in your terminal — agentic coding, Eaon Claw, and chat, for any model: local (Ollama) or hosted (Aqua / BYOK).",
  "type": "module",
  "license": "MIT",
  "bin": {
    "eaon": "./dist/cli.js"
  },
  "engines": {
    "node": ">=18.17"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx src/cli.tsx",
    "start": "node dist/cli.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "cli-highlight": "^2.1.11",
    "commander": "^12.1.0",
    "diff": "^7.0.0",
    "ink": "^5.1.0",
    "open": "^10.1.0",
    "react": "^18.3.1",
    "trash": "^9.0.0"
  },
  "devDependencies": {
    "@types/diff": "^6.0.0",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
