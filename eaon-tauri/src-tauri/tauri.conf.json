{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Eaon",
  "version": "2026.3.0",
  "identifier": "dev.eaon.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Eaon",
        "width": 1040,
        "height": 720,
        "minWidth": 720,
        "minHeight": 480,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}